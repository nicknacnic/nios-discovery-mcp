# Copy to .env and fill in for your NIOS Grid Manager.
# Real env vars take precedence over .env, which takes precedence over gm.ini.

NIOS_GM=192.0.2.10                # your GM hostname or IP
NIOS_API_VERSION=v2.12
NIOS_USER=admin
NIOS_PASS=changeme
NIOS_VERIFY_CERT=false            # set true if your GM has a real cert

# Optional safety net: comma-separated list of GMs that must NEVER receive
# writes from this toolkit. Useful for production grids you only want to read.
# NIOS_READONLY_GMS=prod-gm.example.com,10.0.0.1
